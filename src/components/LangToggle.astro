---
// LangToggle.astro — renders the EN / ES / FR switcher button in the header
---

<div class="flex items-center gap-1 ml-4">
  <button
    id="lang-en"
    aria-label="Switch to English"
    class="lang-btn px-2 py-1 rounded text-sm font-semibold transition-colors duration-200"
  >
    EN
  </button>
  <span class="text-gray-300 select-none">|</span>
  <button
    id="lang-es"
    aria-label="Cambiar a Español"
    class="lang-btn px-2 py-1 rounded text-sm font-semibold transition-colors duration-200"
  >
    ES
  </button>
  <span class="text-gray-300 select-none">|</span>
  <button
    id="lang-fr"
    aria-label="Passer en Français"
    class="lang-btn px-2 py-1 rounded text-sm font-semibold transition-colors duration-200"
  >
    FR
  </button>
</div>

<script>
  import {
    applyTranslations,
    getStoredLang,
    setStoredLang,
  } from "../i18n/i18n";
  import type { Lang } from "../i18n/translations";

  const LANG_IDS: Lang[] = ["en", "es", "fr"];

  function updateButtons(lang: Lang) {
    LANG_IDS.forEach((id) => {
      const btn = document.getElementById(`lang-${id}`)!;
      if (id === lang) {
        btn.classList.add("text-gray-900", "font-bold");
        btn.classList.remove("text-gray-400");
      } else {
        btn.classList.add("text-gray-400");
        btn.classList.remove("text-gray-900", "font-bold");
      }
    });
  }

  function switchLang(lang: Lang) {
    setStoredLang(lang);
    applyTranslations(lang);
    updateButtons(lang);
    window.dispatchEvent(new CustomEvent("langchange", { detail: { lang } }));
  }

  // Initialise on first load
  const current = getStoredLang();
  applyTranslations(current);
  updateButtons(current);

  LANG_IDS.forEach((id) => {
    document
      .getElementById(`lang-${id}`)!
      .addEventListener("click", () => switchLang(id));
  });
</script>
